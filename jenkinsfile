pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - /busybox/cat
    tty: true
    volumeMounts:
      - name: docker-config
        mountPath: /kaniko/.docker
  - name: kubectl
    image: bitnami/kubectl:latest
    command:
    - cat
    tty: true
  volumes:
    - name: docker-config
      secret:
        secretName: dockerhub-secret
'''
        }
    }

    environment {
        // Tu repositorio de Docker Hub
        IMAGE = "rodriguez22/portfolio"
        // El namespace que creamos en tu VPS
        NAMESPACE = "portfolio"
        // El nombre de tu deployment en K8s
        DEPLOYMENT = "portfolio-deploy" 
    }

    stages {
        stage('Descargar Código') {
            steps {
                checkout scm
            }
        }

        stage('Construir y Subir Imagen (Docker Hub)') {
            steps {
                container('kaniko') {
                    sh """
                        /kaniko/executor --context ${WORKSPACE} \
                            --dockerfile deploy/Dockerfile \
                            --destination ${IMAGE}:${BUILD_NUMBER} \
                            --destination ${IMAGE}:latest \
                            --snapshot-mode=redo --single-snapshot
                    """
                }
            }
        }

        stage('Desplegar en VPS (MicroK8s)') {
            steps {
                container('kubectl') {
                    // Esto le dice a Kubernetes que descargue la nueva imagen y reinicie la web sin cortes
                    sh "kubectl rollout restart deployment ${DEPLOYMENT} -n ${NAMESPACE}"
                }
            }
        }
    }
}