pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-admin
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - /busybox/cat
    tty: true
    volumeMounts:
      - name: docker-config
        mountPath: /kaniko/.docker
  - name: kubectl
    image: bitnami/kubectl:latest
    command:
    - cat
    tty: true
  volumes:
    - name: docker-config
      secret:
        secretName: dockerhub-secret
'''
        }
    }

    environment {
        IMAGE = "rodriguez22/portfolio"
        NAMESPACE = "portfolio"
        DEPLOYMENT = "portfolio-deploy" 
    }

    stages {
        stage('Descargar Código') {
            steps {
                checkout scm
            }
        }

        stage('Construir y Subir Imagen') {
            steps {
                container('kaniko') {
                    sh """
                    /kaniko/executor --context ${WORKSPACE} \
                        --dockerfile deploy/Dockerfile \
                        --destination ${IMAGE}:${BUILD_NUMBER} \
                        --destination ${IMAGE}:latest
                    """
                }
            }
        }

        stage('Desplegar en K8s') {
            steps {
                container('kubectl') {
                    sh "kubectl rollout restart deployment ${DEPLOYMENT} -n ${NAMESPACE}"
                }
            }
        }
    }
}