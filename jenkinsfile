pipeline {
    agent {
        kubernetes {
            yaml '''
apiVersion: v1
kind: Pod
spec:
  serviceAccountName: jenkins-admin
  containers:
  - name: kaniko
    image: gcr.io/kaniko-project/executor:debug
    command:
    - /busybox/cat
    tty: true
  - name: kubectl
    image: bitnami/kubectl:latest
    command:
    - cat
    tty: true
'''
        }
    }

    environment {
        IMAGE = "rodriguez22/portfolio"
        NAMESPACE = "portfolio"
        DEPLOYMENT = "portfolio-deploy" 
    }

    stages {
        stage('Descargar Código') {
            steps {
                checkout scm
            }
        }

        stage('Construir y Subir Imagen') {
            steps {
                // AQUÍ USAMOS LA CREDENCIAL QUE HAS CREADO EN JENKINS
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    container('kaniko') {
                        sh '''
                        # Kaniko necesita un archivo especial para la contraseña. Lo creamos aquí:
                        mkdir -p /kaniko/.docker
                        echo "{\\"auths\\":{\\"https://index.docker.io/v1/\\":{\\"auth\\":\\"`echo -n $DOCKER_USER:$DOCKER_PASS | base64`\\"}}}" > /kaniko/.docker/config.json
                        
                        /kaniko/executor --context ${WORKSPACE} \
                            --dockerfile deploy/Dockerfile \
                            --destination ${IMAGE}:${BUILD_NUMBER} \
                            --destination ${IMAGE}:latest
                        '''
                    }
                }
            }
        }

        stage('Desplegar en K8s') {
            steps {
                container('kubectl') {
                    sh "kubectl rollout restart deployment ${DEPLOYMENT} -n ${NAMESPACE}"
                }
            }
        }
    }
}